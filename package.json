{
  "name": "ikon",
  "version": "0.0.0",
  "private": true,
  "description": "Icon discovery by association — search and browse icons with shockwave interactions.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:icons && next build",
    "start": "next start",
    "build:icons": "tsx scripts/build-index.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@phosphor-icons/core": "^2.1.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^2.1.8",
    "iconoir": "^7.10.1",
    "jsdom": "^25.0.1",
    "lucide-static": "^0.468.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^2.1.8"
  }
}
